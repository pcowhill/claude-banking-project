{
  "name": "simbank-monorepo",
  "version": "0.9.0",
  "private": true,
  "type": "module",
  "description": "Meridian (Simulated) — a local-first simulated consumer banking platform with a companion bank-operations simulator. NOT a real bank. No real money, accounts, or financial integrations.",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "postinstall": "npm run db:generate -w @simbank/backend",
    "dev": "concurrently -k -n backend,customer,ops -c blue,green,magenta \"npm:dev:backend\" \"npm:dev:customer\" \"npm:dev:operations\"",
    "dev:backend": "npm run dev -w @simbank/backend",
    "dev:customer": "npm run dev -w @simbank/customer",
    "dev:operations": "npm run dev -w @simbank/operations",
    "build": "npm run build --workspaces --if-present",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install --with-deps chromium",
    "db:generate": "npm run db:generate -w @simbank/backend",
    "db:migrate": "npm run db:migrate -w @simbank/backend",
    "db:reset": "npm run db:reset -w @simbank/backend",
    "db:seed": "npm run db:seed -w @simbank/backend",
    "verify": "npm run lint && npm run typecheck && npm run test && npm run build",
    "clean": "node ./scripts/clean.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "@playwright/test": "^1.48.2",
    "@types/node": "^22.9.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "eslint": "^9.14.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.12.0",
    "postcss": "^8.4.47",
    "prettier": "^3.3.3",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.19.2",
    "typescript": "~5.6.3",
    "typescript-eslint": "^8.13.0",
    "vitest": "^2.1.4"
  }
}
