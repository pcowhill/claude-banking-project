// Meridian (Simulated Bank) — Prisma schema.
//
// LOCAL SIMULATION ONLY. This SQLite database holds nothing but fake, seeded
// demo data. It models real banking concepts so the simulation behaves
// realistically, but it is never connected to real financial systems.
//
// Design note: SQLite has no native enums, so enum-like columns are stored as
// strings whose allowed values live in @simbank/shared (single source of truth).
// Balances are NEVER stored as an editable field — they are derived from the
// append-only LedgerEntry table (see packages/shared/src/ledger.ts).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// A person in the system. Auth (hashing, sessions, RBAC) landed in v0.2.0.
model User {
  id          String   @id @default(cuid())
  email       String   @unique
  displayName String
  role        String   @default("customer") // see UserRole in @simbank/shared
  status      String   @default("active") // active | disabled
  // SIMULATION: a bcrypt hash of a non-secret demo password. Never a real
  // credential. Nullable so a user can exist before a password is set.
  passwordHash      String?
  passwordUpdatedAt DateTime?
  // Lockout bookkeeping (see AUTH in @simbank/shared).
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  lastLoginAt         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  accounts        Account[]
  auditLogs       AuditLog[]          @relation("ActorAudit")
  sessions        Session[]
  accountAccess   AccountAccess[]
  loginEvents     LoginEvent[]
  sentInvitations AccountInvitation[] @relation("InvitedBy")
  cards           Card[]              @relation("CardHolder")
  paymentSchedules PaymentSchedule[]  @relation("ScheduleOwner")
}

/// A server-side session. The opaque token lives ONLY in the user's httpOnly
/// cookie; the database stores just its SHA-256 hash, so a DB leak cannot be
/// replayed as a live session. Standard library hashing only — no custom crypto.
model Session {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique
  createdAt  DateTime  @default(now())
  expiresAt  DateTime
  lastSeenAt DateTime  @default(now())
  revokedAt  DateTime?
  ip         String?
  userAgent  String?

  @@index([userId])
}

/// Grants a user access to an account beyond simple ownership. The primary
/// owner is recorded on Account.userId AND gets an `owner` row here; joint
/// customers / authorized users get `joint`/`authorized`/`viewer` rows. This is
/// how "joint users see only authorized accounts" is enforced.
model AccountAccess {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId    String
  account      Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  relationship String   @default("owner") // see AccountRelationship in @simbank/shared
  createdAt    DateTime @default(now())

  @@unique([userId, accountId])
  @@index([accountId])
}

/// Append-only login history. One row per login ATTEMPT (success or failure),
/// powering the customer's "recent sign-in activity" and the lockout counter.
/// `userId` is null when the attempted email matches no user.
model LoginEvent {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  email     String
  success   Boolean
  reason    String // see LoginReason in @simbank/shared
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

/// A banking product owned by a user (checking, savings, etc.).
model Account {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String // see AccountType in @simbank/shared
  name      String
  currency  String   @default("USD")
  status    String   @default("active") // see AccountStatus in @simbank/shared
  openedAt  DateTime @default(now())
  // v1.0.0: the simulated instant interest has been accrued THROUGH for an
  // interest-bearing account (savings). Null until the first accrual; the accrual
  // driver advances it as the simulation clock passes monthly anniversaries. CDs
  // and loans track accrual on their LendingProduct.lastAccruedAt instead.
  interestAccruedThrough DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ledgerEntries  LedgerEntry[]
  access         AccountAccess[]
  invitations    AccountInvitation[]
  cards          Card[]
  schedulesFrom  PaymentSchedule[]   @relation("ScheduleFrom")
  schedulesTo    PaymentSchedule[]   @relation("ScheduleTo")
  lendingProduct LendingProduct?

  @@index([userId])
}

/// Append-only ledger. Balances are derived from these rows, never edited.
model LedgerEntry {
  id          String    @id @default(cuid())
  accountId   String
  account     Account   @relation(fields: [accountId], references: [id])
  amountMinor Int // ALWAYS positive integer minor units; sign comes from `direction`
  direction   String // credit | debit
  status      String    @default("posted") // pending|posted|held|failed|reversed|disputed
  origin      String // seed|interest|fee|adjustment|transfer|payment|deposit|card
  description String
  reason      String? // required for admin adjustments (audited)
  postedAt    DateTime?
  createdAt   DateTime  @default(now())

  @@index([accountId])
  @@index([status])
}

/// Singleton row holding the simulation clock (fast-forward arrives in v0.9.0).
model SimulationClock {
  id          String   @id @default("singleton")
  currentTime DateTime @default(now())
  speed       Int      @default(1)
  updatedAt   DateTime @updatedAt
}

/// Audit trail for sensitive/administrative actions.
model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  actor     User?    @relation("ActorAudit", fields: [actorId], references: [id])
  actorRole String?
  action    String
  entity    String
  entityId  String?
  reason    String?
  metadata  String? // JSON string
  createdAt DateTime @default(now())

  @@index([entity])
}

/// Work item for the Bank Operations Simulator queues (live in v0.5.0). An
/// operator approves/rejects/holds/requests-info; every action is audited in
/// AuditLog and pushed to operator consoles over Socket.IO. SIMULATION: acting on
/// a request changes its WORKFLOW state only — it never posts to the ledger
/// (money movement arrives in v0.7.0), so balances stay derived.
model OperationsRequest {
  id       String @id @default(cuid())
  type     String // see OpsRequestType in @simbank/shared
  status   String @default("pending") // see OpsRequestStatus in @simbank/shared
  priority String @default("normal") // see OpsRequestPriority in @simbank/shared
  summary  String
  detail   String?
  // The customer/applicant this item concerns. Display only, intentionally NOT a
  // foreign key (e.g. an onboarding applicant is not yet a User).
  subjectName  String?
  subjectEmail String?
  payload      String? // JSON string (simulation context)
  // Most-recent operator action bookkeeping; the full trail lives in AuditLog.
  lastAction     String? // see OpsAction in @simbank/shared
  lastActorId    String?
  lastActorRole  String?
  lastActorName  String?
  lastActionNote String?
  resolvedAt     DateTime? // set when the item reaches a terminal status
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  events                SimulatedEvent[]
  onboardingApplication OnboardingApplication?

  @@index([status])
  @@index([type])
}

/// A SIMULATED external event (SMS / email / MFA / identity). LOCAL SIMULATION
/// ONLY — this NEVER calls a real SMS, email, MFA, or identity provider; it only
/// records a fake event the operations console can display, clearly labelled as
/// simulated. Optionally linked to the OperationsRequest that triggered it.
model SimulatedEvent {
  id        String             @id @default(cuid())
  channel   String // see SimEventChannel in @simbank/shared (sms|email|mfa|identity)
  direction String             @default("outbound") // outbound | inbound
  kind      String? // otp | notification | verification | ...
  status    String             @default("sent") // see SimEventStatus in @simbank/shared
  summary   String
  detail    String?
  requestId String?
  request   OperationsRequest? @relation(fields: [requestId], references: [id], onDelete: SetNull)
  metadata  String? // JSON string
  createdAt DateTime           @default(now())

  @@index([channel])
  @@index([requestId])
  @@index([createdAt])
}

/// A submitted account-opening application (v0.6.0). A public applicant creates
/// one via the open-account flow; it is linked 1:1 to an `OperationsRequest` of
/// type `onboarding`. An operator APPROVING that request is what PROVISIONS the
/// real User + Account + initial funding — initial funding enters via an explicit
/// BANK-ORIGINATED ledger event, audited, balances still derived (money discipline).
/// SIMULATION: fake applicants only; never real identity data or real money.
model OnboardingApplication {
  id                  String   @id @default(cuid())
  reference           String   @unique // short human code shown to the applicant
  status              String   @default("submitted") // submitted | provisioned | rejected (see OnboardingStatus)
  fullName            String
  email               String
  product             String // checking | savings (OnboardingProduct)
  initialFundingMinor Int      @default(0)
  jointInviteEmail    String?
  consentAt           DateTime
  // SIMULATION: bcrypt hash of a non-secret demo password, captured so the
  // approved applicant can sign in. NEVER exposed in any DTO; plaintext never stored.
  passwordHash        String
  // The ops queue item that drives the approval workflow (1:1).
  requestId           String?  @unique
  request             OperationsRequest? @relation(fields: [requestId], references: [id], onDelete: SetNull)
  // Set when an operator approves and provisioning succeeds.
  provisionedUserId    String?
  provisionedAccountId String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([status])
  @@index([email])
}

/// A joint-owner invitation (v0.6.0). An account OWNER invites another person by
/// email; accepting creates a `joint` AccountAccess grant (the same grant RBAC
/// reads), so the invitee then sees the account. SIMULATION: the invite is
/// "delivered" only as a clearly-labelled SimulatedEvent — no real email is sent.
model AccountInvitation {
  id           String   @id @default(cuid())
  token        String   @unique
  accountId    String
  account      Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  invitedById  String
  invitedBy    User     @relation("InvitedBy", fields: [invitedById], references: [id])
  inviteeEmail String
  relationship String   @default("joint") // see AccountRelationship in @simbank/shared
  status       String   @default("pending") // pending | accepted | declined | revoked (InvitationStatus)
  acceptedById String? // the user who accepted (no FK; SIMULATION)
  respondedAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([inviteeEmail])
  @@index([accountId])
}

/// A SIMULATED payment card on an account (v0.8.0). Card SPEND already exists as
/// `card`-origin LedgerEntry rows; this model is the card LIFECYCLE — issue,
/// freeze/unfreeze, report lost/stolen (which issues a replacement), travel
/// notices. SIMULATION: `last4` is fake; there is NEVER a real PAN, network, or
/// issuer. Acting on a card changes its lifecycle state + writes an audit row —
/// it NEVER posts to the ledger, so balances stay derived.
model Card {
  id        String  @id @default(cuid())
  accountId String
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  // The cardholder (the account owner / accessor who holds the card).
  userId    String
  user      User    @relation("CardHolder", fields: [userId], references: [id])
  cardType  String // debit | credit (see CardType in @simbank/shared)
  network   String // visa | mastercard (DISPLAY ONLY; SIMULATION)
  last4     String // simulated last four digits — never a real PAN
  expMonth  Int
  expYear   Int
  status    String  @default("active") // active|frozen|lost|stolen|replaced|cancelled (CardStatus)
  // When this card is a replacement for a reported lost/stolen card, the id of
  // the card it replaced (self-link; SIMULATION, no FK constraint needed).
  replacesCardId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  travelNotices CardTravelNotice[]

  @@index([accountId])
  @@index([userId])
}

/// A SIMULATED travel notice on a card (v0.8.0): the customer tells the bank they
/// will be travelling so card activity from a destination is not flagged. No
/// money or real systems involved.
model CardTravelNotice {
  id          String   @id @default(cuid())
  cardId      String
  card        Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  destination String
  startsOn    DateTime
  endsOn      DateTime
  note        String?
  status      String   @default("active") // active | cancelled (TravelNoticeStatus)
  createdAt   DateTime @default(now())

  @@index([cardId])
}

/// A SIMULATED recurring / scheduled payment (v0.9.0). The customer schedules a
/// future-dated or recurring `internal_transfer` (between their own accounts) or
/// `bill_pay` (to a biller). When the SIMULATION CLOCK passes `nextRunAt`, the
/// scheduler FIRES it by appending real LedgerEntry rows via the v0.7.0 money
/// service — an internal transfer posts BOTH `transfer` legs (nets to zero), a
/// bill pay writes a PENDING `payment` debit + a linked OperationsRequest an
/// operator approves. MONEY DISCIPLINE: this row holds only the INSTRUCTIONS; it
/// never stores or edits a balance, and firing is the only thing that moves money.
model PaymentSchedule {
  id     String @id @default(cuid())
  // The owner who created the schedule; the firing actor, so access can never
  // exceed what this user already holds on the accounts involved.
  userId String
  user   User   @relation("ScheduleOwner", fields: [userId], references: [id], onDelete: Cascade)
  kind   String // internal_transfer | bill_pay (see ScheduleKind in @simbank/shared)
  // Source account (debited). For internal_transfer, `toAccountId` is the destination.
  fromAccountId String
  fromAccount   Account @relation("ScheduleFrom", fields: [fromAccountId], references: [id], onDelete: Cascade)
  toAccountId   String?
  toAccount     Account? @relation("ScheduleTo", fields: [toAccountId], references: [id], onDelete: SetNull)
  // Biller / payee label for a bill pay (display only; SIMULATION).
  counterparty String?
  memo         String?
  amountMinor  Int // positive integer minor units
  frequency    String // once | weekly | monthly (see ScheduleFrequency)
  // Next due date, read against the SIMULATION clock. Null once terminal.
  nextRunAt DateTime?
  status    String    @default("active") // active | completed | cancelled (ScheduleStatus)
  // Firing bookkeeping (the actual money lives in the ledger, not here).
  lastRunAt DateTime?
  runCount  Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId])
  @@index([status])
  @@index([nextRunAt])
}

/// A SIMULATED lending/deposit product (v1.0.0): a Certificate of Deposit (CD) or
/// a loan, layered 1:1 onto a dedicated `cd`/`loan` Account. This row holds only
/// the TERMS (rate, term, principal, maturity, the loan's level payment) and the
/// accrual bookmark; the MONEY lives in the account's append-only ledger:
///  - a CD account carries a POSITIVE balance (deposit + earned `interest` credits);
///  - a loan account carries a NEGATIVE balance (amount owed) that interest `debit`s
///    grow and `transfer` payments shrink toward zero.
/// Opening, paying, and withdrawing move money as net-zero `transfer` leg pairs;
/// interest accrual posts bank-originated `interest` entries dated at the SIMULATED
/// accrual date. MONEY DISCIPLINE: this row never stores or edits a balance, and
/// balances stay DERIVED from the ledger. SIMULATION: no real lender/depositor.
model LendingProduct {
  id        String  @id @default(cuid())
  // The product's own account (a `cd` or `loan` Account); 1:1.
  accountId String  @unique
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  kind      String // cd | loan (see LendingKind in @simbank/shared)
  status    String  @default("active") // active | matured | paid_off | closed (LendingStatus)
  // Opening principal in minor units (the CD deposit / the loan amount).
  principalMinor Int
  // Annual rate in basis points (e.g. 450 = 4.50%).
  apyBps         Int
  termMonths     Int
  // Level monthly payment for a loan; null for a CD.
  paymentMinor   Int?
  // Simulated instants: when the product opened / matures / was last accrued through.
  openedAt      DateTime
  maturesAt     DateTime
  lastAccruedAt DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status])
  @@index([kind])
}
