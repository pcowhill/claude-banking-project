// Meridian (Simulated Bank) — Prisma schema.
//
// LOCAL SIMULATION ONLY. This SQLite database holds nothing but fake, seeded
// demo data. It models real banking concepts so the simulation behaves
// realistically, but it is never connected to real financial systems.
//
// Design note: SQLite has no native enums, so enum-like columns are stored as
// strings whose allowed values live in @simbank/shared (single source of truth).
// Balances are NEVER stored as an editable field — they are derived from the
// append-only LedgerEntry table (see packages/shared/src/ledger.ts).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// A person in the system. Auth (hashing, sessions, RBAC) landed in v0.2.0.
model User {
  id          String   @id @default(cuid())
  email       String   @unique
  displayName String
  role        String   @default("customer") // see UserRole in @simbank/shared
  status      String   @default("active") // active | disabled
  // SIMULATION: a bcrypt hash of a non-secret demo password. Never a real
  // credential. Nullable so a user can exist before a password is set.
  passwordHash      String?
  passwordUpdatedAt DateTime?
  // Lockout bookkeeping (see AUTH in @simbank/shared).
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  lastLoginAt         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  accounts      Account[]
  auditLogs     AuditLog[]      @relation("ActorAudit")
  sessions      Session[]
  accountAccess AccountAccess[]
  loginEvents   LoginEvent[]
}

/// A server-side session. The opaque token lives ONLY in the user's httpOnly
/// cookie; the database stores just its SHA-256 hash, so a DB leak cannot be
/// replayed as a live session. Standard library hashing only — no custom crypto.
model Session {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique
  createdAt  DateTime  @default(now())
  expiresAt  DateTime
  lastSeenAt DateTime  @default(now())
  revokedAt  DateTime?
  ip         String?
  userAgent  String?

  @@index([userId])
}

/// Grants a user access to an account beyond simple ownership. The primary
/// owner is recorded on Account.userId AND gets an `owner` row here; joint
/// customers / authorized users get `joint`/`authorized`/`viewer` rows. This is
/// how "joint users see only authorized accounts" is enforced.
model AccountAccess {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId    String
  account      Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  relationship String   @default("owner") // see AccountRelationship in @simbank/shared
  createdAt    DateTime @default(now())

  @@unique([userId, accountId])
  @@index([accountId])
}

/// Append-only login history. One row per login ATTEMPT (success or failure),
/// powering the customer's "recent sign-in activity" and the lockout counter.
/// `userId` is null when the attempted email matches no user.
model LoginEvent {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  email     String
  success   Boolean
  reason    String // see LoginReason in @simbank/shared
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

/// A banking product owned by a user (checking, savings, etc.).
model Account {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String // see AccountType in @simbank/shared
  name      String
  currency  String   @default("USD")
  status    String   @default("active") // see AccountStatus in @simbank/shared
  openedAt  DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ledgerEntries LedgerEntry[]
  access        AccountAccess[]

  @@index([userId])
}

/// Append-only ledger. Balances are derived from these rows, never edited.
model LedgerEntry {
  id          String    @id @default(cuid())
  accountId   String
  account     Account   @relation(fields: [accountId], references: [id])
  amountMinor Int // ALWAYS positive integer minor units; sign comes from `direction`
  direction   String // credit | debit
  status      String    @default("posted") // pending|posted|held|failed|reversed|disputed
  origin      String // seed|interest|fee|adjustment|transfer|payment|deposit|card
  description String
  reason      String? // required for admin adjustments (audited)
  postedAt    DateTime?
  createdAt   DateTime  @default(now())

  @@index([accountId])
  @@index([status])
}

/// Singleton row holding the simulation clock (fast-forward arrives in v0.9.0).
model SimulationClock {
  id          String   @id @default("singleton")
  currentTime DateTime @default(now())
  speed       Int      @default(1)
  updatedAt   DateTime @updatedAt
}

/// Audit trail for sensitive/administrative actions.
model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  actor     User?    @relation("ActorAudit", fields: [actorId], references: [id])
  actorRole String?
  action    String
  entity    String
  entityId  String?
  reason    String?
  metadata  String? // JSON string
  createdAt DateTime @default(now())

  @@index([entity])
}

/// Work item for the Bank Operations Simulator queues (live in v0.5.0). An
/// operator approves/rejects/holds/requests-info; every action is audited in
/// AuditLog and pushed to operator consoles over Socket.IO. SIMULATION: acting on
/// a request changes its WORKFLOW state only — it never posts to the ledger
/// (money movement arrives in v0.7.0), so balances stay derived.
model OperationsRequest {
  id       String @id @default(cuid())
  type     String // see OpsRequestType in @simbank/shared
  status   String @default("pending") // see OpsRequestStatus in @simbank/shared
  priority String @default("normal") // see OpsRequestPriority in @simbank/shared
  summary  String
  detail   String?
  // The customer/applicant this item concerns. Display only, intentionally NOT a
  // foreign key (e.g. an onboarding applicant is not yet a User).
  subjectName  String?
  subjectEmail String?
  payload      String? // JSON string (simulation context)
  // Most-recent operator action bookkeeping; the full trail lives in AuditLog.
  lastAction     String? // see OpsAction in @simbank/shared
  lastActorId    String?
  lastActorRole  String?
  lastActorName  String?
  lastActionNote String?
  resolvedAt     DateTime? // set when the item reaches a terminal status
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  events SimulatedEvent[]

  @@index([status])
  @@index([type])
}

/// A SIMULATED external event (SMS / email / MFA / identity). LOCAL SIMULATION
/// ONLY — this NEVER calls a real SMS, email, MFA, or identity provider; it only
/// records a fake event the operations console can display, clearly labelled as
/// simulated. Optionally linked to the OperationsRequest that triggered it.
model SimulatedEvent {
  id        String             @id @default(cuid())
  channel   String // see SimEventChannel in @simbank/shared (sms|email|mfa|identity)
  direction String             @default("outbound") // outbound | inbound
  kind      String? // otp | notification | verification | ...
  status    String             @default("sent") // see SimEventStatus in @simbank/shared
  summary   String
  detail    String?
  requestId String?
  request   OperationsRequest? @relation(fields: [requestId], references: [id], onDelete: SetNull)
  metadata  String? // JSON string
  createdAt DateTime           @default(now())

  @@index([channel])
  @@index([requestId])
  @@index([createdAt])
}
