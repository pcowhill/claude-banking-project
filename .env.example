# =============================================================================
# Meridian (Simulated Bank) — example environment configuration
# =============================================================================
# This is a LOCAL SIMULATION. None of these values connect to real banking,
# payment, SMS, or email systems. Copy this file to `.env` and adjust if needed.
#
#   PowerShell:  Copy-Item .env.example .env
#   bash/WSL:    cp .env.example .env
#
# Most local development works with the defaults below and does not require
# a `.env` file at all.
# =============================================================================

# ---- Backend ----------------------------------------------------------------
# Port the Fastify API + Socket.IO server listens on.
PORT=3000

# Prisma / SQLite database location (relative to apps/backend/prisma).
# This is a local file-based database; it holds only fake, seeded demo data.
DATABASE_URL="file:./dev.db"

# Comma-separated list of allowed browser origins for CORS.
CORS_ORIGINS="http://localhost:5173,http://localhost:5174"

# Node environment: development | test | production
NODE_ENV=development

# ---- Frontend apps (Vite) ---------------------------------------------------
# Base URL the customer and operations apps use to reach the backend API.
# Vite only exposes variables prefixed with VITE_ to client code.
VITE_API_URL="http://localhost:3000"
VITE_WS_URL="http://localhost:3000"
